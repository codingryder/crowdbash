# Database (Neon)
DATABASE_URL=postgresql://user:password@host/crowdbash?sslmode=require

# Upstash Redis
UPSTASH_REDIS_URL=https://your-instance.upstash.io
UPSTASH_REDIS_TOKEN=your_token_here

# Auth (custom JWT - no Supabase)
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRY_HOURS=72

# Email OTP (Resend - free 3000 emails/month)
RESEND_API_KEY=re_your_resend_key
FROM_EMAIL=noreply@crowdbash.codingryder.com

# CricketData.org (https://cricketdata.org)
CRICKETDATA_API_KEY=your_cricketdata_key

# Football-Data.org (https://football-data.org)
FOOTBALL_API_KEY=your_football_data_key

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_secret

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=["http://localhost:5173"]
